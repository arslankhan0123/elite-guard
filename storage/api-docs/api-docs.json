                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "All NFC tags fetched."
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
